# ============================================================
# .claudeignore — bifriends-be
# Claude가 읽지 않아도 되는 파일을 제외해 토큰 낭비를 방지합니다.
# ============================================================

# ─── Gradle 빌드 산출물 ───────────────────────────────────────
build/
.gradle/
out/
bin/

# Gradle Wrapper는 버전 확인에 필요하므로 유지
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ─── Kotlin / Java 컴파일 캐시 ────────────────────────────────
**/*.class
**/*.jar
**/*.war

# ─── IDE 설정 ────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.classpath
.project
.factorypath
.apt_generated
.springBeans
.sts4-cache

# ─── 보안 / 시크릿 (절대 Claude에 노출 금지) ──────────────────
.env
.env.*
*service-account*.json
bifriends-*-firebase-adminsdk-*.json
src/main/resources/firebase-service-account.json

# ─── OS 메타데이터 ────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp

# ─── 로그 ───────────────────────────────────────────────────
logs/
*.log
*.log.*

# ─── Docker 볼륨 / 런타임 데이터 ──────────────────────────────
docker-data/
postgres_data/

# ─── Git 내부 ────────────────────────────────────────────────
.git/

# ─── 테스트 리포트 (분석 불필요한 HTML 리포트) ─────────────────
build/reports/
build/test-results/

# ─── Spring Boot DevTools 캐시 ────────────────────────────────
spring-devtools.properties

# ─── 불필요한 문서 ───────────────────────────────────────────
HELP.md
