# PostgreSQL
DB_NAME=bifriends
DB_USERNAME=bifriends
DB_PASSWORD=강력한비밀번호로교체

# JWT (256비트 이상 랜덤값)
# 생성: openssl rand -base64 64
JWT_SECRET=

# Gemini AI
GOOGLE_API_KEY=

# BE ↔ AI 내부 인증 토큰 (랜덤값)
# 생성: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=

# Firebase
FIREBASE_STORAGE_BUCKET=bifriends-5df72.firebasestorage.app
# Firestore DB ID (콘솔에서 이름 지정 DB를 만든 경우 그 ID, 예: bifriends)
FIRESTORE_DATABASE_ID=bifriends

# Firebase 폴백 이미지 토큰 (application.yml의 defaultValue 참고)
