      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git pull)",
      "Bash(git fetch *)",

      "Bash(curl http://localhost:*)",
      "Bash(curl http://127.0.0.1:*)",

